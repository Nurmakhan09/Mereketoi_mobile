# Mereketoi mobile — environment.
# Expo inlines EXPO_PUBLIC_* variables at build time. Copy to `.env` to override.

# API / web origin (no trailing slash, no /api/v1). Defaults to production.
# Local backend example (Windows host IP, WSL backend on port 8899):
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:8899
EXPO_PUBLIC_API_URL=https://mereketoi.kz
